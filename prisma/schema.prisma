generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Car {
  id                String   @id @default(uuid())
  brand             String
  model             String
  year              Int
  price_avg         Decimal  @db.Decimal(12, 2)
  type              String
  imageUrl          String?
  fipe_code         String?  @unique
  moderation_status String   @default("pending")
  source            String?
  source_data       Json?

  spec      Spec?
  images    CarImage[]
  feedbacks Feedback[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brand])
  @@index([model])
  @@index([price_avg])
  @@index([moderation_status])
}

model Spec {
  id                       String  @id @default(uuid())
  carId                    String  @unique
  car                      Car     @relation(fields: [carId], references: [id], onDelete: Cascade)

  trunk_liters             Int     @default(0)
  tank_capacity            Int     @default(0)
  wheelbase                Float   @default(0)
  ground_clearance         Int     @default(0)
  fuel_consumption_city    Float   @default(0)
  fuel_consumption_highway Float?
  fuel_type                String  @default("Flex")
  transmission             String  @default("Automático")
  hp                       Int?
  acceleration             Float?

  trunk_score              Int     @default(0)
  wheelbase_score          Int     @default(0)
  ground_clearance_score   Int     @default(0)
  consumption_score        Int     @default(0)
  hp_score                 Int     @default(0)
  acceleration_score       Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trunk_liters])
  @@index([fuel_consumption_city])
  @@index([tank_capacity])
}

model CarImage {
  id        String   @id @default(uuid())
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  url       String
  source    String
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([carId])
  @@index([isPrimary])
}

model Feedback {
  id        String   @id @default(uuid())
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  thumbs    Boolean
  weights   Json?
  createdAt DateTime @default(now())

  @@index([carId])
}

model IngestionJob {
  id          String          @id @default(uuid())
  status      String          @default("pending")
  startedAt   DateTime?
  completedAt DateTime?
  carsAdded   Int             @default(0)
  carsUpdated Int             @default(0)
  carsSkipped Int             @default(0)
  errors      Json?
  logs        IngestionLog[]
  createdAt   DateTime        @default(now())

  @@index([status])
  @@index([createdAt])
}

model IngestionLog {
  id             String        @id @default(uuid())
  jobId          String
  job            IngestionJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  source         String
  status         String        @default("pending")
  itemsProcessed Int           @default(0)
  errors         Json?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime      @default(now())

  @@index([jobId])
  @@index([source])
}

model RejectedCar {
  id         String   @id @default(uuid())
  fipe_code  String   @unique
  brand      String
  model      String
  year       Int
  reason     String?
  rejectedAt DateTime @default(now())

  @@index([brand, model, year])
}
